# ==============================================================================
# Environment Configuration - Employee Attendance & Management System
# ==============================================================================
# Copy this file to '.env' and fill in your actual configuration values.
# DO NOT commit '.env' containing sensitive keys/passwords to GitHub.

# Server Configuration
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000

# Security
# Run `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"` to generate a secure secret.
JWT_SECRET=your_jwt_secret_key_here

# PostgreSQL Connection Credentials (App Runtime)
SQL_HOST=127.0.0.1
SQL_PORT=5432
SQL_USER=postgres
SQL_PASSWORD=your_database_password
SQL_DB_NAME=employee_attendance_db

# PostgreSQL Connection Credentials (Drizzle Admin/Migrations)
SQL_ADMIN_USER=postgres
SQL_ADMIN_PASSWORD=your_database_password

# Gemini API Integration (Optional / Feature Flagged)
GEMINI_API_KEY=your_gemini_api_key_here
